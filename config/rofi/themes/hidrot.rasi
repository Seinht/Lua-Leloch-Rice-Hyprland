window {
  background-color: @bg0;
  border: 2px;
  border-color: @white-trans;
  border-radius: 0px;
  padding: 6px;
}

mainbox {
  children: [inputbar, listview];
}

inputbar {
  background-color: @white-trans;
  border: 0 0 0 2px;
  border-color: @white;
  border-radius: 0px;
  margin: 0 0 6px 0;
}

entry {
  padding: 10px;
  text-color: @white;
}

listview {
  lines: 10;
}
/*
element {
  border: 0 0 0 2px;
  border-radius: 6px;
  padding: 10px;
}
*/

element {
  border: 0 0 0 2px;
  border-radius: 0px;
  padding: 10px;
}

element selected {
  background-color: @red-trans;
  border-color: @red;
}

element-text {
  text-color: @fg0;
}

element-text selected {
  text-color: @red;
}
